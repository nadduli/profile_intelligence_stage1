# --- Database ---
# Neon (or any Postgres) connection string. Use the asyncpg driver.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/profile_intelligence

# Optional: enable SQLAlchemy query logging (default: false)
DEBUG=false

# --- GitHub OAuth — Web app ---
# Register at https://github.com/settings/developers
# Authorization callback URL: <BACKEND_PUBLIC_URL>/auth/github/callback
GITHUB_WEB_CLIENT_ID=your_web_client_id_here
GITHUB_WEB_CLIENT_SECRET=your_web_client_secret_here

# --- GitHub OAuth — CLI app ---
# Separate app required because the callback URL differs.
# Authorization callback URL: http://127.0.0.1:<GITHUB_CLI_CALLBACK_PORT>/callback
GITHUB_CLI_CLIENT_ID=your_cli_client_id_here
GITHUB_CLI_CLIENT_SECRET=your_cli_client_secret_here
GITHUB_CLI_CALLBACK_PORT=51420

# --- JWT signing ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 chars. Rotate immediately if leaked.
JWT_SECRET=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=180   # 3 minutes (per spec)
REFRESH_TOKEN_TTL_SECONDS=300  # 5 minutes (per spec)

# --- URLs ---
# BACKEND_PUBLIC_URL: where the backend is reachable from the browser/CLI.
# WEB_APP_ORIGIN: where the React app is served from. Used for CORS + post-login redirect.
BACKEND_PUBLIC_URL=http://localhost:8000
WEB_APP_ORIGIN=http://localhost:5173

# --- Cookies (web auth flow) ---
# COOKIE_SECURE: must be true in production (HTTPS); false for local http dev.
# COOKIE_SAMESITE: "lax" for same-site or same-registrable-domain.
#                  Use "none" + COOKIE_SECURE=true for cross-domain cookies.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=  # leave blank to default to current host
